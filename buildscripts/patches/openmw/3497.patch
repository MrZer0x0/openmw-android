     {
+        auto [translation, rotation, scale] = GetCurrentTransformation(nv);
+
+        if (rotation)
+        {
+            osg::Quat lerpedRot;
+            lerpedRot.slerp(1.0f, node->getmRotation(), *rotation);
+            node->setRotation(lerpedRot);
+        }
